# Relay docker image for claude-distant
# Python 3.12 FastAPI + WebSocket broker + MCP server

FROM python:3.12-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy relay source and requirements
COPY relay/ /app/relay/
COPY relay/requirements.txt /app/requirements.txt

# Install Python dependencies
RUN pip install --no-cache-dir -r /app/requirements.txt

# Environment variables (can be overridden at runtime)
ENV HOST=0.0.0.0
ENV PORT=8000
ENV CLIENT_TOKEN=
ENV MCP_BEARER_TOKEN=
ENV SESSION_TTL_SECONDS=1800

# Expose the relay port
EXPOSE ${PORT}

# Health check
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD curl -f http://localhost:${PORT}/healthz || exit 1

# Run relay with uvicorn
# Assumes FastAPI app is instantiated as 'app' in relay/app.py or relay/__init__.py
CMD ["sh", "-c", "uvicorn relay.app:app --host ${HOST} --port ${PORT}"]
