# Reverse proxy TLS strict pour claude-distant (voir docs/SECURITY.md).
#
# Termine le TLS à la frontière (Let's Encrypt automatique via TLS_DOMAIN, ou
# certificat fourni manuellement — voir commentaire `tls` ci-dessous) et
# reproxy en clair vers le relay sur le réseau Docker interne
# (`relay:8000`, jamais exposé directement à Internet en déploiement `tls`).
#
# Alternative Nginx : voir `docker/nginx.conf.example` (mêmes garanties —
# TLS 1.2+, HSTS, en-têtes de sécurité, WebSocket upgrade — pour qui préfère
# gérer ses certificats manuellement plutôt que l'ACME automatique de Caddy).

{$TLS_DOMAIN:relay.example.com} {
	# TLS 1.2 minimum (comportement historique du "harnais MCP + client Go
	# distant" : jamais de client legacy à supporter en dessous). Caddy gère
	# l'obtention/le renouvellement automatique du certificat (Let's Encrypt)
	# pour TLS_DOMAIN ; pour un certificat fourni manuellement, remplacer par
	# `tls /path/to/cert.pem /path/to/key.pem` à l'intérieur du même bloc.
	tls {
		protocols tls1.2 tls1.3
	}

	encode gzip zstd

	# En-têtes de sécurité stricts. HSTS avec un TTL long : ce relay n'est
	# jamais censé être servi en clair une fois le déploiement TLS activé.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		-Server
	}

	# WebSocket (client PC distant) + MCP Streamable HTTP (harnais) partagent
	# le même reverse_proxy : Caddy détecte et upgrade automatiquement les
	# connexions WebSocket (en-tête `Connection: Upgrade`), pas de bloc séparé
	# nécessaire. `flush_interval -1` désactive le buffering de réponse,
	# indispensable pour le streaming SSE du transport MCP Streamable HTTP et
	# pour la latence du canal WebSocket.
	reverse_proxy relay:8000 {
		flush_interval -1
	}
}

# Redirection HTTP -> HTTPS : comportement par défaut de Caddy dès qu'un site
# HTTPS est défini pour ce nom d'hôte (un site `http://` miroir est généré
# automatiquement et redirige en 308 vers la version `https://`) — aucune
# configuration supplémentaire requise ici.
