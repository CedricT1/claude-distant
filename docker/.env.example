# claude-distant relay environment configuration
# Copy this file to .env and configure with your actual values

# Relay host binding (default: 0.0.0.0 to listen on all interfaces)
HOST=0.0.0.0

# Relay port (default: 8000)
PORT=8000

# Bearer token for client authentication (WebSocket connection)
# IMPORTANT: Change this to a strong secret value in production
CLIENT_TOKEN=change-me

# Bearer token for MCP server authentication (harnais/Claude connection)
# IMPORTANT: Change this to a strong secret value in production
MCP_BEARER_TOKEN=change-me

# Session code TTL in seconds (default: 1800 = 30 minutes)
# Lower values increase security, higher values improve UX for slow/distant connections
SESSION_TTL_SECONDS=1800

# Optional: Redis connection URL (for distributed session store)
# If not set, relay will use in-memory session store (single-instance only)
# REDIS_URL=redis://localhost:6379

# Optional: Enable debug logging (false by default)
# DEBUG=false
