# claude-distant relay environment configuration
# Copy this file to .env and configure with your actual values

# Relay host binding (default: 0.0.0.0 to listen on all interfaces)
HOST=0.0.0.0

# Relay port (default: 8000)
PORT=8000

# Bearer token for client authentication (WebSocket connection)
# IMPORTANT: Change this to a strong secret value in production
CLIENT_TOKEN=change-me

# Client auth mode: "shared" (default, single pre-shared CLIENT_TOKEN for all
# clients) or "per_session" (short-lived, single-use tokens minted on demand
# via the issue_client_token MCP tool -- see relay/auth.py:PerSessionTokenStore).
CLIENT_AUTH_MODE=shared

# Bearer token for MCP server authentication (harnais/Claude connection),
# used when MCP_AUTH_MODE=static_bearer (default).
# IMPORTANT: Change this to a strong secret value in production
MCP_BEARER_TOKEN=change-me

# MCP harness auth mode: "static_bearer" (default, single pre-shared
# MCP_BEARER_TOKEN, unchanged MVP behavior) or "oauth" (OAuth 2.1 resource
# server, scoped JWT bearer tokens -- see relay/jwt_auth.py, relay/mcp_server.py).
MCP_AUTH_MODE=static_bearer

# HS256 signing secret for MCP JWTs (MCP_AUTH_MODE=oauth only).
# IMPORTANT: generate a long random secret in production, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Tokens are minted with: python -m relay.tokens issue --sub <name> \
#   --scopes session:connect,command:execute,session:terminate,client:provision \
#   --ttl 3600
# MCP_JWT_SECRET=change-me

# JWT signing algorithm (default: HS256). Only used when MCP_AUTH_MODE=oauth.
MCP_JWT_ALGORITHM=HS256

# Optional: OAuth issuer / resource server URL metadata exposed by the MCP
# SDK (mode oauth only). Self-issued by default (relay/mcp_server.py); only
# override if you need these to match a real public hostname (recommended in
# production, e.g. the hostname behind the TLS reverse proxy -- see
# docker/Caddyfile / docker/nginx.conf.example).
# MCP_JWT_ISSUER_URL=https://relay.example.com/
# MCP_JWT_RESOURCE_SERVER_URL=https://relay.example.com/mcp

# Session code TTL in seconds (default: 1800 = 30 minutes)
# Lower values increase security, higher values improve UX for slow/distant connections
# Also used as the default TTL for tokens minted by the issue_client_token MCP tool.
SESSION_TTL_SECONDS=1800

# Optional: command allow/denylist and quotas (see relay/command_policy.py).
# Patterns are regexes separated by ";". Denylist always wins over allowlist.
# COMMAND_DENYLIST=rm\s+-rf\s+/;mkfs
# COMMAND_ALLOWLIST=
# MAX_COMMANDS_PER_SESSION=
# RATE_LIMIT_PER_MINUTE=

# Optional: path to the tamper-evident JSONL audit log (see relay/audit.py).
# Defaults to ./audit.log if unset; the compose file maps this under
# ./logs so it survives container restarts.
AUDIT_LOG_PATH=/app/logs/audit.log

# Optional: public hostname for the TLS reverse proxy (docker-compose
# --profile tls, see docker/Caddyfile). Caddy requests/renews a Let's
# Encrypt certificate for this hostname automatically.
# TLS_DOMAIN=relay.example.com

# Optional: Redis connection URL (for distributed session store)
# If not set, relay will use in-memory session store (single-instance only)
# REDIS_URL=redis://localhost:6379

# Optional: Enable debug logging (false by default)
# DEBUG=false
