# Alternative Nginx au Caddyfile (docker/Caddyfile) pour qui gère déjà ses
# propres certificats TLS (pas d'ACME automatique ici, contrairement à Caddy).
# Voir docs/SECURITY.md pour le modèle de menace et le choix TLS strict.
#
# Usage : copier vers nginx.conf, ajuster `server_name`/chemins de certificat,
# monter en volume `:ro` dans un service `nginx:1.27-alpine` du
# docker-compose, sur le même réseau que `relay` (voir le service `caddy`
# dans docker/docker-compose.yml pour un exemple de service à adapter).

worker_processes auto;

events {
    worker_connections 1024;
}

http {
    # Redirection stricte HTTP -> HTTPS.
    server {
        listen 80;
        server_name relay.example.com;
        return 301 https://$host$request_uri;
    }

    server {
        listen 443 ssl http2;
        server_name relay.example.com;

        ssl_certificate     /etc/nginx/tls/fullchain.pem;
        ssl_certificate_key /etc/nginx/tls/privkey.pem;

        # TLS 1.2 minimum, suites modernes uniquement.
        ssl_protocols TLSv1.2 TLSv1.3;
        ssl_prefer_server_ciphers on;
        ssl_ciphers HIGH:!aNULL:!MD5:!3DES:!RC4;
        ssl_session_cache shared:SSL:10m;
        ssl_session_timeout 10m;

        add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header X-Frame-Options "DENY" always;
        add_header Referrer-Policy "no-referrer" always;
        server_tokens off;

        # WebSocket (client PC distant, /ws/client) + MCP Streamable HTTP
        # (harnais, /mcp) : même reverse proxy, upgrade WebSocket explicite
        # (Nginx ne le détecte pas automatiquement comme Caddy).
        location / {
            proxy_pass http://relay:8000;
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "upgrade";
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            # Pas de buffering : indispensable pour le streaming SSE du
            # transport MCP Streamable HTTP et la latence du canal WebSocket.
            proxy_buffering off;
            proxy_read_timeout 3600s;
        }
    }
}
